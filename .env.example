AI_MODEL=gpt-5-mini
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# Supabase project URL is public configuration.
NEXT_PUBLIC_SUPABASE_URL=https://rlvcjdhmhfwnwbzjndaz.supabase.co
SUPABASE_URL=https://rlvcjdhmhfwnwbzjndaz.supabase.co

# Browser-safe Supabase key. Use either naming style.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase key. Never expose this with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Optional admin/test controls.
